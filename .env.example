# BaseContable Environment Variables

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/basecontable?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Google OAuth (para autenticación con Google)
# Obtener desde: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Frontend Google Client ID (mismo valor que GOOGLE_CLIENT_ID)
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here

# Server Configuration
PORT=5000
NODE_ENV=development

# Email Configuration (para notificaciones)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# MercadoPago (para pagos - opcional)
MP_ACCESS_TOKEN=your_mp_access_token
MP_WEBHOOK_SECRET=your_webhook_secret

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3000
